# GitLab Context Configuration for AI Assist Service
# Copy this file to .env and configure with your GitLab instance values

# Seat IDs for billing events (comma-separated list)
GITLAB_SEAT_IDS=seat-1,seat-2,seat-3

# Unique instance identifier for this GitLab instance
GITLAB_UNIQUE_INSTANCE_ID=gitlab-instance-abc123

# Root namespace ID (ultimate parent namespace)
GITLAB_ROOT_NAMESPACE_ID=123

# Alternative: Use existing GitLab instance ID
GITLAB_INSTANCE_ID=gitlab-instance-456

# Note: If these values are not set, the service will generate fallback values
# - Seat IDs will be generated based on user ID or random UUID
# - Unique instance ID will be generated as a random UUID
# - Root namespace ID will use the current namespace ID as fallback
